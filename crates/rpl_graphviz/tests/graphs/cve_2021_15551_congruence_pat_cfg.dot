digraph ControlFlowGraph {
    bb0 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb0</td></tr><tr><td align="left" balign="left">_?0 = Not(_)<br/>_?1 = Ne(_, _)<br/></td></tr><tr><td align="left">switchInt(move _?1) -&gt; [false: ?bb2, otherwise: ?bb7]</td></tr></table>>];
    bb1 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb1</td></tr><tr><td align="left" balign="left">_?3 = copy _?2 as *const u8 (PtrToPtr)<br/>_?4 = core::ptr::NonNull:: &lt; u8 &gt; { pointer: copy _?3 }<br/>_?5 = core::ptr::Unique:: &lt; u8 &gt; { pointer: move _?4, _marker: _ }<br/>_?6 = alloc::raw_vec::RawVecInner { ptr: move _?5, cap: _, alloc: _ }<br/>_?7 = alloc::raw_vec::RawVec:: &lt; ?T0 &gt; { inner: move _?6, _marker: _ }<br/>_?8 = alloc::vec::Vec:: &lt; ?T0 &gt; { buf: move _?7, len: _ }<br/></td></tr><tr><td align="left">drop(_?8) -&gt; ?bb8</td></tr></table>>];
    bb2 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb2</td></tr><tr><td align="left">switchInt(move _?0) -&gt; [false: ?bb4, otherwise: ?bb5]</td></tr></table>>];
    bb3 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb3</td></tr><tr><td align="left">goto ?bb1</td></tr></table>>];
    bb4 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb4</td></tr><tr><td align="left">goto ?bb3</td></tr></table>>];
    bb5 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb5</td></tr><tr><td align="left">goto ?bb6</td></tr></table>>];
    bb6 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb6</td></tr><tr><td align="left">return</td></tr></table>>];
    bb7 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb7</td></tr><tr><td align="left">goto ?bb6</td></tr></table>>];
    bb8 [shape="none", label=<<table border="0" cellborder="1" cellspacing="0"><tr><td  align="center" colspan="1">?bb8</td></tr><tr><td align="left">end</td></tr></table>>];
    bb0 -> bb2 [label="0"];
    bb0 -> bb7 [label="otherwise"];
    bb1 -> bb8 [label="goto"];
    bb2 -> bb4 [label="0"];
    bb2 -> bb5 [label="otherwise"];
    bb3 -> bb1 [label="goto"];
    bb4 -> bb3 [label="goto"];
    bb5 -> bb6 [label="goto"];
    bb7 -> bb6 [label="goto"];
}
