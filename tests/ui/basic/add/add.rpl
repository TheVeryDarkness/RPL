pattern a

patt {
    foo = unsafe? fn _(..) -> _ {
        'x:
        let $x: usize = _;
        'y:
        let $y: usize = _;
        'z:
        let $z: usize = Add(copy $x, copy $y);
    }
}

diag {
    foo = {
        primary(z)      = "added value here",
        label(x)        = "first value here",
        label(y)        = "second value here",
        name            = "foo",
    }
}
