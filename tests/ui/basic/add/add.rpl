pattern a

patt {
    foo[$T: type where is_copy(self)] = unsafe? fn _(..) -> _ {
        'x:
        let $x: $T;
        'y:
        let $y: $T;
        'z:
        let $z: $T = Add(move $x, move $y);
    }
}

diag {
    foo = {
        primary(z)     = "added value here",
        help(x)        = "first value here",
        help(y)        = "second value here",
        name           = "foo",
    }
}
